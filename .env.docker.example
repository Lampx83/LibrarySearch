# Port cho ứng dụng (frontend nginx). Mặc định 3002.
HTTP_PORT=3002

# Đường dẫn thư mục dữ liệu *trong container* (backend mount volume tại /data).
# Nếu dùng named volume "library-data" thì giữ /data.
# Nếu mount bind host (xem docker-compose) thì trỏ đúng path trong container.
LIBRARY_DATA_DIR=/data
